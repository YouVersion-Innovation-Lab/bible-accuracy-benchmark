# Secrets and local config — never commit
.env
.env.*
!.env.example
*.pem
*.key

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
dist/
build/

# Node / web
node_modules/
web/dist/

# Local eval results (may contain fetched verse text — never commit)
results/
runs/

# Local Bible-text cache (operator convenience; contains verse text — never commit)
bible-cache/
*.biblecache/

# OS / editor
.DS_Store
.idea/
.vscode/

# Stray shell redirect artifacts (e.g. a file literally named "1" or "2")
/[0-9]

# Local web-review demo data
web-review-results/
