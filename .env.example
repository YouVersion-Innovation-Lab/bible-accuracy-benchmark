# Copy to .env and fill in. NEVER commit real values — this repo is public.
# All values stay LOCAL: evaluations run from this machine via the CLI. No model
# keys are ever needed in GitHub or GCP — the website reads finished results
# from a bucket and fetches nothing live.

# --- YouVersion Bible API access (required for ground-truth verse text) ---
# Provided out-of-band to authorized operators.
# YV_API_HEADERS is a JSON object of request headers, e.g. {"Header-Name": "value", ...}
YV_API_BASE_URL=
YV_API_HEADERS=

# --- Models under test -------------------------------------------------------
# One key per provider. Each run picks the provider's OpenAI-compatible base URL
# and the key named here via `bible-bench run --base-url … --api-key-env …`.
# First-party APIs for the big three (canonical models, no aggregator routing):
#   OpenAI     base https://api.openai.com/v1
#   Anthropic  base https://api.anthropic.com/v1
#   Gemini     base https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Open-weight targets (Llama/Qwen/DeepSeek/…) via one aggregator key:
#   OpenRouter base https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
# Optional first-party extras:
XAI_API_KEY=
DEEPSEEK_API_KEY=

# --- Adversarial harness (the pinned attacker model) -------------------------
# A fixed open-weight model via OpenRouter; the judge is deterministic, so this
# only generates attack prompts. Point HARNESS_API_KEY at your OpenRouter key.
HARNESS_BASE_URL=https://openrouter.ai/api/v1
HARNESS_API_KEY=
HARNESS_MODEL=deepseek/deepseek-chat-v3.1
