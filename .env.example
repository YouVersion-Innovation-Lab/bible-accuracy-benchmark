# Copy to .env and fill in. NEVER commit real values — this repo is public.
# Everything here stays LOCAL: evaluations run from this machine via the CLI.
# No keys are ever needed in GitHub or GCP — the website reads finished results
# from a bucket and fetches nothing live.

# --- YouVersion Bible API access (required for ground-truth verse text) ------
# Provided out-of-band to authorized operators.
# YV_API_HEADERS is a JSON object of request headers, e.g. {"Header-Name": "value", ...}
YV_API_BASE_URL=
YV_API_HEADERS=

# --- Model under test --------------------------------------------------------
# You do NOT set the target key here. Pass it per run, either by exporting a
# named env var for that one command or by pasting it at the hidden prompt:
#
#   OPENAI_KEY=sk-… bible-bench run \
#     --base-url https://api.openai.com/v1 --api-key-env OPENAI_KEY \
#     --model gpt-5.2 --label "GPT-5.2" --gcs-bucket <bucket>
#
#   # or omit the key entirely and paste it when prompted (hidden input)
#   bible-bench run --base-url … --model … --label … --gcs-bucket …
#
# Provider base URLs (OpenAI-compatible):
#   OpenAI     https://api.openai.com/v1
#   Anthropic  https://api.anthropic.com/v1
#   Gemini     https://generativelanguage.googleapis.com/v1beta/openai/
#   OpenRouter https://openrouter.ai/api/v1   (open-weight models)
#   xAI        https://api.x.ai/v1
#   DeepSeek   https://api.deepseek.com

# --- Adversarial harness (the pinned attacker model) -------------------------
# A fixed open-weight model via OpenRouter; the judge is deterministic, so this
# only generates attack prompts. Set once for adversarial-track runs.
HARNESS_BASE_URL=https://openrouter.ai/api/v1
HARNESS_API_KEY=
HARNESS_MODEL=deepseek/deepseek-chat-v3.1
