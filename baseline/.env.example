# baseline/.env — LOCAL ONLY, gitignored. Copy to `.env` and fill in.
#
# This service is an INDEPENDENT OpenAI-compatible chat interface over jittle
# (Jot & Tittle). It knows nothing about the benchmark. Nothing here is required
# by, or shared with, the benchmark website.

# --- Generation LLM (OpenAI-compatible: key / endpoint / model) --------------
# jittle's chat generates Tier B/C answers through this endpoint. Quote accuracy
# is guaranteed by jittle's verification engine regardless of the model you pick.
# Leave any of these blank to run WITHOUT generation: Tier A (direct quotes) and
# refusals still work; topical answers degrade to jittle's safe no-synthesis body.
BASELINE_LLM_BASE_URL=https://api.anthropic.com/v1
BASELINE_LLM_API_KEY=sk-ant-...
BASELINE_LLM_MODEL=claude-sonnet-5

# The model id this service advertises on GET /v1/models and echoes back.
BASELINE_MODEL_ID=jot-tittle

# --- jittle (Jot & Tittle) engine ------------------------------------------
# Absolute path to the built public-domain corpus (see scripts/build_data.sh).
JOT_CORPUS=/ABSOLUTE/PATH/TO/baseline/vendor/jittle/data/corpus.db

# YouVersion PLATFORM key (developers.youversion.com) — enables licensed versions
# (NIV/NLT/ESV/...). This is a DIFFERENT credential from the benchmark's Core API.
# Blank = public-domain only (BSB/KJV/WEB/ASV); a request for an unreachable
# version falls back to BSB (jittle marks the substitution, never silent).
JOT_YVP_KEY=

# Grounded-Composition path. Leave unset for jittle's robust legacy generate+verify
# path (works with any endpoint). CANTOR=1 is tuned for Claude models only.
# CANTOR=1
