      "strategy": "stratified_random",
      "min_verses_per_book": 2,
      "english_count": 200,
      "other_language_count": 25
    },
    "obscure": {
      "strategy": "obscure_pools",
      "pools": ["genealogy", "census", "psalm119_interior", "number_heavy", "minor_prophet_interior", "longest_verses"],
      "english_count": 75,
      "other_language_count": 10
    },
    "edge": {
      "strategy": "edge_pools",
      "pools": ["single_chapter_books", "chapter_final_verses", "book_final_verses"],
      "english_count": 25,
      "other_language_count": 5
    }
  },
